{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "npm": {
    "extends": ["npm:unpublishSafe"]
  },
  "packageRules": [
    {
      "groupName": "minor and patch updates",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "groupName": "major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
